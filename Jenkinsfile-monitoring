pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Checkout the repository code
                checkout scm
            }
        }
        
        stage('Deploy Monitoring Stack to Minikube') {
            steps {
                script {
                    echo 'Deploying Prometheus and Grafana to Kubernetes...'
                    // CHANGED: Use 'sh' for WSL Linux and removed 'K8s/' prefix
                    sh 'kubectl apply -f Prometheus-deployment.yml'
                    sh 'kubectl apply -f Grafana-deployment.yml'
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                script {
                    echo 'Checking pod and service status...'
                    // CHANGED: Use 'sh' for WSL Linux
                    sh 'kubectl get pods -l app=prometheus'
                    sh 'kubectl get pods -l app=grafana'
                    sh 'kubectl get svc prometheus-service'
                    sh 'kubectl get svc grafana-service'
                }
            }
        }
    }

    post {
        success {
            echo 'Monitoring stack (Prometheus & Grafana) deployed successfully to Minikube!'
        }
        failure {
            echo 'Failed to deploy the monitoring stack. Please check the logs.'
        }
    }
}